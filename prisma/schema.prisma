generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())

  email String @unique
  nickname String

  bookmarks Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String  @id @default(cuid())
  title       String
  description String?

  category EventCategory

  venueName String  @default("Unknown")
  address   String?
  lat       Float?
  lng       Float?

  images String[]

  website String?

  startDate DateTime
  endDate   DateTime

  isFeatured Boolean @default(false)

  bookmarks Bookmark[]

  viewCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventCategory {
  EXHIBITION
  POPUP
  FESTIVAL
  PERFORMANCE
  ETC
}

model Bookmark {
  id String @id @default(cuid())

  userId String
  eventId String

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}
